{% extends 'base.html.twig' %}

{% block title %}Nova cobrança{% endblock %}

{% block body %}
<!-- Breadcrumbs & Header -->
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>COBRANÇAS</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">NOVO REGISTRO</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Gerar Nova Cobrança</h2>
        <p class="font-body-md text-on-surface-variant/60">Preencha os dados para criar um novo ciclo de faturamento.</p>
    </div>
    <a href="{{ path('admin_billings') }}" class="font-label-md text-primary hover:underline underline-offset-8 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        VOLTAR
    </a>
</div>

{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="bg-surface-container-high border-l-4 border-primary p-4 mb-8 flex items-start gap-4">
            <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">info</span>
            <p class="font-label-md text-label-md text-on-surface">{{ message }}</p>
        </div>
    {% endfor %}
{% endfor %}

<form method="post" class="billing-form" id="billing-form">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Billing Form Section (Left) -->
        <div class="lg:col-span-7 space-y-12">
            <section class="space-y-8">
                <h3 class="font-headline-sm text-headline-sm text-primary flex items-center gap-3">
                    <span class="material-symbols-outlined">edit_note</span>
                    Especificações do Tratamento
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <!-- Patient Selection -->
                    <div class="relative group md:col-span-2">
                        <select name="patient_id" required class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all text-body-lg text-primary appearance-none cursor-pointer" style="border-radius: 0;">
                            <option value="" disabled selected></option>
                            {% for patient in patients %}
                                <option value="{{ patient.id }}">{{ patient.name }} - {{ patient.company.name }}</option>
                            {% endfor %}
                        </select>
                        <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none" for="patient_id">Identificação do Paciente</label>
                        <div class="absolute right-0 top-3 text-outline/40">
                            <span class="material-symbols-outlined">person_search</span>
                        </div>
                    </div>

                    <!-- Total Amount -->
                    <div class="relative group">
                        <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" id="total_amount" name="total_amount" placeholder=" " type="number" min="0" step="1" required>
                        <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none" for="total_amount">Valor Total do Procedimento (R$)</label>
                        <div class="absolute right-0 top-3 text-outline/40">
                            <span class="material-symbols-outlined">payments</span>
                        </div>
                    </div>

                    <!-- Entry Amount -->
                    <div class="relative group">
                        <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" id="entry_amount" name="entry_amount" placeholder=" " type="number" min="0" step="1" required>
                        <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none" for="entry_amount">Pagamento de Entrada (R$)</label>
                        <div class="absolute right-0 top-3 text-outline/40">
                            <span class="material-symbols-outlined">input</span>
                        </div>
                    </div>

                    <!-- Installments -->
                    <div class="relative group md:col-span-2">
                        <div class="flex items-center justify-between mb-2">
                            <label class="text-on-surface-variant font-label-md">Ciclos de Parcelamento</label>
                            <span class="text-primary font-bold text-headline-sm" id="installment_count">3</span>
                        </div>
                        <input class="w-full h-1 bg-surface-container-high rounded-lg appearance-none cursor-pointer accent-primary-container" id="installment_slider" name="installments_count" type="range" min="1" max="24" step="1" value="3">
                        <div class="flex justify-between mt-2 text-[10px] text-outline font-label-sm uppercase tracking-widest">
                            <span>01 Mês</span>
                            <span>24 Meses</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Actions -->
            <div class="pt-8 flex flex-col md:flex-row items-center gap-8">
                <button type="submit" class="w-full md:w-auto gold-gradient-btn px-10 py-4 text-on-primary font-bold uppercase tracking-[0.2em] flex items-center justify-center gap-3" style="border: none; cursor: pointer;">
                    <span class="material-symbols-outlined">verified</span>
                    Selar e Distribuir
                </button>
                <a href="{{ path('admin_billings') }}" class="w-full md:w-auto text-secondary font-label-md uppercase tracking-widest border border-outline-variant/15 px-10 py-4 hover:bg-surface-container-low transition-colors text-center" style="text-decoration: none;">
                    Descartar Rascunho
                </a>
            </div>
        </div>

        <!-- Distributor Logic Preview (Right) -->
        <div class="lg:col-span-5">
            <div class="distributor-preview sticky top-32">
                <div class="flex justify-between items-start">
                    <div>
                        <h4 class="font-headline-sm text-headline-sm text-primary">Distribuidor de Cobrança</h4>
                        <p class="text-on-surface-variant font-label-sm mt-1">PRÉ-VISUALIZAÇÃO LÓGICA</p>
                    </div>
                    <div class="bg-surface-container-high p-3 flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">analytics</span>
                    </div>
                </div>

                <div class="bg-surface-container-low p-6 flex flex-col gap-4 border-l-4 border-primary">
                    <div class="flex justify-between text-label-sm text-outline uppercase tracking-widest">
                        <span>Saldo Remanescente</span>
                        <span>Frequência</span>
                    </div>
                    <div class="flex justify-between items-end">
                        <span class="font-display-lg text-[32px] text-primary" id="preview_remaining">R$ 0,00</span>
                        <span class="font-label-md text-on-surface mb-1">Mensal</span>
                    </div>
                </div>

                <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar" id="installment_list">
                    <!-- Generated by JS -->
                </div>

                <div class="mt-4 pt-6 border-t border-outline-variant/15 flex flex-col gap-2">
                    <div class="flex justify-between items-center text-outline font-label-sm uppercase tracking-widest">
                        <span>Impacto Tributário Estimado</span>
                        <span class="text-on-surface">2.4% Est.</span>
                    </div>
                    <div class="flex justify-between items-center text-outline font-label-sm uppercase tracking-widest">
                        <span>Estratégia de Recebimento</span>
                        <span class="text-on-surface">Livro Distribuído</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('installment_slider');
    const countDisplay = document.getElementById('installment_count');
    const totalInput = document.getElementById('total_amount');
    const entryInput = document.getElementById('entry_amount');
    const previewRemaining = document.getElementById('preview_remaining');
    const installmentList = document.getElementById('installment_list');

    function updatePreview() {
        const count = parseInt(slider.value) || 3;
        const total = parseFloat(totalInput.value) || 0;
        const entry = parseFloat(entryInput.value) || 0;
        const remaining = Math.max(0, total - entry);
        const perInstallment = count > 0 ? (remaining / count) : 0;

        countDisplay.innerText = count;
        previewRemaining.innerText = 'R$ ' + remaining.toFixed(2).replace('.', ',');

        // Generate installment preview
        const now = new Date();
        const months = ['JAN', 'FEV', 'MAR', 'ABR', 'MAI', 'JUN', 'JUL', 'AGO', 'SET', 'OUT', 'NOV', 'DEZ'];
        let html = '';
        for (let i = 1; i <= Math.min(count, 24); i++) {
            const dueDate = new Date(now.getFullYear(), now.getMonth() + i, now.getDate());
            const label = i === 1 ? 'INÍCIO DO LIVRO' : (i === count ? 'ACERTO FINAL' : 'RECORRENTE');
            const isDimmed = i > 3 && i < count;
            html += `
                <div class="flex items-center justify-between py-4 border-b border-outline-variant/10 group hover:bg-surface-container-high px-2 transition-colors ${isDimmed ? 'opacity-50' : ''}">
                    <div class="flex items-center gap-4">
                        <span class="text-outline font-label-sm font-mono">${String(i).padStart(2, '0')}/${String(count).padStart(2, '0')}</span>
                        <div class="flex flex-col">
                            <span class="text-on-surface font-label-md">${String(dueDate.getDate()).padStart(2, '0')} ${months[dueDate.getMonth()]} ${dueDate.getFullYear()}</span>
                            <span class="text-[10px] text-outline font-label-sm">${label}</span>
                        </div>
                    </div>
                    <span class="text-primary font-bold">R$ ${perInstallment.toFixed(2).replace('.', ',')}</span>
                </div>
            `;
        }
        if (count > 4) {
            html = html.replace(/RECORRENTE/g, 'RECORRENTE');
        }
        installmentList.innerHTML = html;
    }

    if (slider) slider.addEventListener('input', updatePreview);
    if (totalInput) totalInput.addEventListener('input', updatePreview);
    if (entryInput) entryInput.addEventListener('input', updatePreview);

    // Initial preview
    setTimeout(updatePreview, 100);

    // Form validation
    const form = document.getElementById('billing-form');
    if (form) {
        form.addEventListener('submit', (e) => {
            const total = parseFloat(totalInput?.value || 0);
            const entry = parseFloat(entryInput?.value || 0);
            const patientSelect = form.querySelector('select[name="patient_id"]');

            if (entry > total) {
                e.preventDefault();
                alert('A entrada não pode ser maior que o valor total.');
                return;
            }
            if (patientSelect && !patientSelect.value) {
                e.preventDefault();
                alert('Selecione um paciente.');
                return;
            }
        });
    }
});
</script>
{% endblock %}