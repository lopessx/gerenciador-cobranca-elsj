{% extends 'base.html.twig' %}

{% block title %}Cobranças{% endblock %}

{% block body %}
<!-- Breadcrumbs & Header -->
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>COBRANÇAS</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">TODOS OS REGISTROS</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Cobranças</h2>
        <p class="font-body-md text-on-surface-variant/60">Registros de faturamento e ciclo de cobranças.</p>
    </div>
    <a href="{{ path('admin_billings_new') }}" class="gold-gradient-btn px-6 py-3 text-on-primary font-label-md text-label-md rounded flex items-center gap-2" style="text-decoration: none;">
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">add</span>
        <span>Nova Cobrança</span>
    </a>
</div>

<!-- Document List -->
<div class="space-y-[80px]">
    {% for billing in billings %}
    <div class="flex flex-col md:flex-row md:items-center justify-between group">
        <div class="flex-1 bg-surface-container-low border-l-4 border-primary p-8 relative overflow-hidden transition-all duration-300 hover:bg-surface-container-high">
            <div class="flex flex-wrap items-start justify-between gap-6">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="px-3 py-1 bg-surface-container-high text-label-sm text-primary uppercase ghost-border">{{ billing.status }}</span>
                        <span class="font-label-sm text-on-surface-variant opacity-60">FAT-{{ billing.id|slice(0, 8)|upper }}</span>
                    </div>
                    <h3 class="font-headline-lg text-headline-lg text-on-surface mb-1">{{ billing.patient.name }}</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">{{ billing.company.name }}</p>
                    <p class="font-label-sm text-on-surface-variant/60 mt-2">{{ billing.installments|length }} parcela(s)</p>
                </div>
                <div class="text-right">
                    <div class="font-label-sm text-on-surface-variant uppercase tracking-widest mb-1">Valor Devido</div>
                    <div class="font-headline-lg text-headline-lg text-primary">R$ {{ (billing.totalAmount / 100)|number_format(2, ',', '.') }}</div>
                    <div class="font-label-sm text-on-surface-variant mt-2">Entrada: R$ {{ (billing.entryAmount / 100)|number_format(2, ',', '.') }}</div>
                </div>
            </div>
            <div class="absolute right-4 bottom-4 opacity-0 group-hover:opacity-100 transition-opacity flex gap-4">
                <a href="{{ path('admin_billings_show', {id: billing.id}) }}" class="material-symbols-outlined text-primary text-3xl cursor-pointer" style="font-variation-settings: 'FILL' 1;">visibility</a>
                <a href="{{ path('admin_billings_delete', {id: billing.id}) }}" class="material-symbols-outlined text-error text-3xl cursor-pointer" onclick="return confirm('Excluir esta cobrança?')">delete</a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="bg-surface-container-low p-8 text-center">
        <p class="font-body-md text-on-surface-variant">Nenhuma cobrança cadastrada.</p>
    </div>
    {% endfor %}
</div>
{% endblock %}