{% extends 'base.html.twig' %}

{% block title %}Pacientes{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="admin-header">
        <h1>Pacientes</h1>
        <a href="{{ path('admin_patients_new') }}" class="theme-toggle">Novo paciente</a>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th>Empresa</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            {% for patient in patients %}
                <tr>
                    <td>{{ patient.name }}</td>
                    <td>{{ patient.cpf }}</td>
                    <td>{{ patient.email }}</td>
                    <td>{{ patient.phone }}</td>
                    <td>{{ patient.company.name }}</td>
                    <td>
                        <a href="{{ path('admin_patients_edit', {id: patient.id}) }}" class="table-link">Editar</a>
                        <a href="{{ path('admin_patients_delete', {id: patient.id}) }}" class="table-link danger">Excluir</a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6">Nenhum paciente cadastrado.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}