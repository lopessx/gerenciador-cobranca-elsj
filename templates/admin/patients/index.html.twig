{% extends 'base.html.twig' %}

{% block title %}Pacientes{% endblock %}

{% block body %}
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>PACIENTES</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">TODOS OS REGISTROS</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Pacientes</h2>
        <p class="font-body-md text-on-surface-variant/60">Registro de pacientes e histórico de tratamento.</p>
    </div>
    <a href="{{ path('admin_patients_new') }}" class="gold-gradient-btn px-6 py-3 text-on-primary font-label-md text-label-md rounded flex items-center gap-2" style="text-decoration: none;">
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">add</span>
        <span>Novo Paciente</span>
    </a>
</div>

<div class="space-y-[80px]">
    {% for patient in patients %}
    <div class="flex flex-col md:flex-row md:items-center justify-between group">
        <div class="flex-1 bg-surface-container-low border-l-4 border-primary p-8 relative overflow-hidden transition-all duration-300 hover:bg-surface-container-high">
            <div class="flex flex-wrap items-start justify-between gap-6">
                <div>
                    <h3 class="font-headline-lg text-headline-lg text-on-surface mb-1">{{ patient.name }}</h3>
                    <div class="flex items-center gap-3 mt-2 flex-wrap">
                        <span class="px-3 py-1 bg-surface-container-high text-label-sm text-primary uppercase ghost-border">{{ patient.cpf }}</span>
                        <span class="font-label-sm text-on-surface-variant opacity-60">{{ patient.company.name }}</span>
                    </div>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-2">{{ patient.email }}</p>
                </div>
                <div class="text-right">
                    <div class="font-label-sm text-on-surface-variant uppercase tracking-widest mb-1">Telefone</div>
                    <div class="font-headline-sm text-headline-sm text-on-surface">{{ patient.phone }}</div>
                </div>
            </div>
            <div class="absolute right-4 bottom-4 opacity-0 group-hover:opacity-100 transition-opacity flex gap-4">
                <a href="{{ path('admin_patients_edit', {id: patient.id}) }}" class="material-symbols-outlined text-primary text-3xl cursor-pointer" style="font-variation-settings: 'FILL' 1;">edit</a>
                <a href="{{ path('admin_patients_delete', {id: patient.id}) }}" class="material-symbols-outlined text-error text-3xl cursor-pointer" onclick="return confirm('Excluir este paciente?')">delete</a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="bg-surface-container-low p-8 text-center">
        <p class="font-body-md text-on-surface-variant">Nenhum paciente cadastrado.</p>
    </div>
    {% endfor %}
</div>
{% endblock %}