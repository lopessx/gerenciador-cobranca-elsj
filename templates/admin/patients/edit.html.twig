{% extends 'base.html.twig' %}

{% block title %}Editar paciente{% endblock %}

{% block body %}
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>PACIENTES</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">EDITAR REGISTRO</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Editar Paciente</h2>
        <p class="font-body-md text-on-surface-variant/60">{{ patient.name }}</p>
    </div>
    <a href="{{ path('admin_patients') }}" class="font-label-md text-primary hover:underline underline-offset-8 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        VOLTAR
    </a>
</div>

<form method="post" class="billing-form">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="name" placeholder=" " type="text" value="{{ patient.name }}" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Nome</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="email" placeholder=" " type="email" value="{{ patient.email }}">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">E-mail</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="cpf" placeholder=" " type="text" value="{{ patient.cpf }}" maxlength="11" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">CPF</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="phone" placeholder=" " type="text" value="{{ patient.phone }}" maxlength="15">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Telefone</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="birthday" placeholder=" " type="date" value="{{ patient.birthday ? patient.birthday|date('Y-m-d') : '' }}">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Data de Nascimento</label>
        </div>
        <div class="relative group">
            <select name="company_id" required class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all text-body-lg text-primary appearance-none cursor-pointer" style="border-radius: 0;">
                <option value="" disabled></option>
                {% for company in companies %}
                    <option value="{{ company.id }}" {% if patient.company.id == company.id %}selected{% endif %}>{{ company.name }}</option>
                {% endfor %}
            </select>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Empresa</label>
        </div>
        <div class="flex items-center gap-3 py-3">
            <input type="checkbox" name="no_email" id="no_email_checkbox" class="accent-primary-container w-4 h-4" {% if patient.noEmail %}checked{% endif %}>
            <label for="no_email_checkbox" class="text-on-surface-variant font-label-md cursor-pointer">Não tem e-mail</label>
        </div>
    </div>
    <div class="pt-8 flex flex-col md:flex-row items-center gap-8">
        <button type="submit" class="gold-gradient-btn px-10 py-4 text-on-primary font-bold uppercase tracking-[0.2em] flex items-center justify-center gap-3" style="border: none; cursor: pointer;">
            <span class="material-symbols-outlined">update</span>
            Atualizar Paciente
        </button>
        <a href="{{ path('admin_patients') }}" class="text-secondary font-label-md uppercase tracking-widest border border-outline-variant/15 px-10 py-4 hover:bg-surface-container-low transition-colors" style="text-decoration: none;">
            Cancelar
        </a>
    </div>
</form>
{% endblock %}