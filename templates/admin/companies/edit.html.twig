{% extends 'base.html.twig' %}

{% block title %}Editar empresa{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="admin-header">
        <h1>Editar empresa</h1>
        <a href="{{ path('admin_companies') }}" class="theme-toggle">Voltar</a>
    </div>

    <form method="post" class="auth-form">
        <label>Nome<input type="text" name="name" value="{{ company.name }}" required></label>
        <label>Razão social<input type="text" name="razao_social" value="{{ company.razaoSocial }}"></label>
        <label>E-mail<input type="email" name="email" value="{{ company.email }}"></label>
        <label>Entrada mínima (centavos)<input type="number" name="min_entry_amount" min="0" step="1" value="{{ company.minEntryAmount }}"></label>
        <button type="submit">Atualizar</button>
    </form>
</div>
{% endblock %}
