{% extends 'base.html.twig' %}

{% block title %}Editar empresa{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="admin-header">
        <h1>Editar empresa</h1>
        <a href="{{ path('admin_companies') }}" class="theme-toggle">Voltar</a>
    </div>

    <form method="post" class="auth-form">
        <label>Nome<input type="text" name="name" value="{{ company.name }}" required></label>
        <label>CNPJ<input type="text" name="cnpj" value="{{ company.cnpj }}" maxlength="18" placeholder="00.000.000/0000-00"></label>
        <label>E-mail<input type="email" name="email" value="{{ company.email }}"></label>
        <label>E-mail padrão para pacientes sem e-mail<input type="email" name="default_patient_email" value="{{ company.defaultPatientEmail }}" placeholder="ex: sememail@empresa.com"></label>
        <button type="submit">Atualizar</button>
    </form>
</div>
{% endblock %}