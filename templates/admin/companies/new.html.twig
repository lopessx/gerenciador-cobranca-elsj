{% extends 'base.html.twig' %}

{% block title %}Nova empresa{% endblock %}

{% block body %}
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>EMPRESAS</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">NOVO REGISTRO</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Nova Empresa</h2>
        <p class="font-body-md text-on-surface-variant/60">Cadastre uma nova clínica ou instituição parceira.</p>
    </div>
    <a href="{{ path('admin_companies') }}" class="font-label-md text-primary hover:underline underline-offset-8 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        VOLTAR
    </a>
</div>

<form method="post" class="billing-form">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="name" placeholder=" " type="text" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Nome</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="cnpj" placeholder=" " type="text" maxlength="18">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">CNPJ</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="email" placeholder=" " type="email">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">E-mail</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="default_patient_email" placeholder=" " type="email">
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">E-mail padrão (pacientes sem e-mail)</label>
        </div>
    </div>
    <div class="pt-8 flex flex-col md:flex-row items-center gap-8">
        <button type="submit" class="gold-gradient-btn px-10 py-4 text-on-primary font-bold uppercase tracking-[0.2em] flex items-center justify-center gap-3" style="border: none; cursor: pointer;">
            <span class="material-symbols-outlined">save</span>
            Salvar Empresa
        </button>
        <a href="{{ path('admin_companies') }}" class="text-secondary font-label-md uppercase tracking-widest border border-outline-variant/15 px-10 py-4 hover:bg-surface-container-low transition-colors" style="text-decoration: none;">
            Cancelar
        </a>
    </div>
</form>
{% endblock %}