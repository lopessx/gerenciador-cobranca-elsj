{% extends 'base.html.twig' %}

{% block title %}Nova empresa{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="admin-header">
        <h1>Nova empresa</h1>
        <a href="{{ path('admin_companies') }}" class="theme-toggle">Voltar</a>
    </div>

    <form method="post" class="auth-form">
        <label>Nome<input type="text" name="name" required></label>
        <label>CNPJ<input type="text" name="cnpj" maxlength="18" placeholder="00.000.000/0000-00"></label>
        <label>E-mail<input type="email" name="email"></label>
        <label>E-mail padrão para pacientes sem e-mail<input type="email" name="default_patient_email" placeholder="ex: sememail@empresa.com"></label>
        <button type="submit">Salvar</button>
    </form>
</div>
{% endblock %}