{% extends 'base.html.twig' %}

{% block title %}Novo usuário{% endblock %}

{% block body %}
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>USUÁRIOS</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">NOVO REGISTRO</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Novo Usuário</h2>
        <p class="font-body-md text-on-surface-variant/60">Crie uma nova conta de acesso ao sistema.</p>
    </div>
    <a href="{{ path('admin_users') }}" class="font-label-md text-primary hover:underline underline-offset-8 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        VOLTAR
    </a>
</div>

{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="bg-surface-container-high border-l-4 border-primary p-4 mb-8 flex items-start gap-4">
            <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">info</span>
            <p class="font-label-md text-label-md text-on-surface">{{ message }}</p>
        </div>
    {% endfor %}
{% endfor %}

<form method="post" class="billing-form">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="name" placeholder=" " type="text" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Nome</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="email" placeholder=" " type="email" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">E-mail</label>
        </div>
        <div class="relative group">
            <input class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all placeholder-transparent text-body-lg text-primary" name="password" placeholder=" " type="password" required>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Senha</label>
        </div>
        <div class="relative group">
            <select name="role" required class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all text-body-lg text-primary appearance-none cursor-pointer" style="border-radius: 0;">
                <option value="" disabled selected></option>
                {% for role, label in roles %}
                    <option value="{{ role }}">{{ label }}</option>
                {% endfor %}
            </select>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Perfil</label>
        </div>
        <div class="relative group md:col-span-2">
            <select name="company_ids[]" multiple class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 px-0 focus:ring-0 focus:border-primary focus:border-b-2 transition-all text-body-lg text-primary cursor-pointer" style="border-radius: 0; min-height: 100px;">
                {% for company in companies %}
                    <option value="{{ company.id }}">{{ company.name }}</option>
                {% endfor %}
            </select>
            <label class="absolute left-0 top-3 text-on-surface-variant font-label-md transition-all origin-left pointer-events-none">Empresas (segure Ctrl para múltiplas)</label>
        </div>
    </div>
    <div class="pt-8 flex flex-col md:flex-row items-center gap-8">
        <button type="submit" class="gold-gradient-btn px-10 py-4 text-on-primary font-bold uppercase tracking-[0.2em] flex items-center justify-center gap-3" style="border: none; cursor: pointer;">
            <span class="material-symbols-outlined">person_add</span>
            Salvar Usuário
        </button>
        <a href="{{ path('admin_users') }}" class="text-secondary font-label-md uppercase tracking-widest border border-outline-variant/15 px-10 py-4 hover:bg-surface-container-low transition-colors" style="text-decoration: none;">
            Cancelar
        </a>
    </div>
</form>
{% endblock %}