{% extends 'base.html.twig' %}

{% block title %}Editar usuário{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="admin-header">
        <h1>Editar usuário</h1>
        <a href="{{ path('admin_users') }}" class="theme-toggle">Voltar</a>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <p class="flash-message">{{ message }}</p>
        {% endfor %}
    {% endfor %}

    <form method="post" class="auth-form">
        <label>Nome<input type="text" name="name" value="{{ user.name }}" required></label>
        <label>E-mail<input type="email" name="email" value="{{ user.email }}" required></label>
        <label>Senha (deixe em branco para não alterar)<input type="password" name="password"></label>
        <label>Perfil
            <select name="role" required>
                {% for role, label in roles %}
                    <option value="{{ role }}" {% if user.roles[0] == role %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Empresas
            <select name="company_ids[]" multiple>
                {% for company in companies %}
                    <option value="{{ company.id }}" {% if user.getCompanies().contains(company) %}selected{% endif %}>{{ company.name }}</option>
                {% endfor %}
            </select>
        </label>
        <button type="submit">Atualizar</button>
    </form>
</div>
{% endblock %}