{% extends 'base.html.twig' %}

{% block title %}Usuários{% endblock %}

{% block body %}
<div class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
    <span>USUÁRIOS</span>
    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
    <span class="text-primary">TODOS OS REGISTROS</span>
</div>

<div class="flex justify-between items-end mb-12">
    <div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-2">Usuários</h2>
        <p class="font-body-md text-on-surface-variant/60">Contas de acesso e permissões do sistema.</p>
    </div>
    <a href="{{ path('admin_users_new') }}" class="gold-gradient-btn px-6 py-3 text-on-primary font-label-md text-label-md rounded flex items-center gap-2" style="text-decoration: none;">
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">add</span>
        <span>Novo Usuário</span>
    </a>
</div>

<div class="space-y-[80px]">
    {% for user in users %}
    <div class="flex flex-col md:flex-row md:items-center justify-between group">
        <div class="flex-1 bg-surface-container-low border-l-4 border-primary p-8 relative overflow-hidden transition-all duration-300 hover:bg-surface-container-high">
            <div class="flex flex-wrap items-start justify-between gap-6">
                <div>
                    <h3 class="font-headline-lg text-headline-lg text-on-surface mb-1">{{ user.name }}</h3>
                    <div class="flex items-center gap-3 mt-2 flex-wrap">
                        <span class="px-3 py-1 bg-surface-container-high text-label-sm text-primary uppercase ghost-border">{{ user.getRoleLabel() }}</span>
                        {% if user.isActive() %}
                            <span class="px-3 py-1 bg-surface-container-high text-label-sm text-secondary uppercase ghost-border">Ativo</span>
                        {% else %}
                            <span class="px-3 py-1 bg-surface-container-high text-label-sm text-error uppercase ghost-border">Inativo</span>
                        {% endif %}
                    </div>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-2">{{ user.email }}</p>
                    <p class="font-label-sm text-on-surface-variant/60 mt-1">{{ user.getCompanies()|length }} empresa(s) vinculada(s)</p>
                </div>
            </div>
            <div class="absolute right-4 bottom-4 opacity-0 group-hover:opacity-100 transition-opacity flex gap-4">
                <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="material-symbols-outlined text-primary text-3xl cursor-pointer" style="font-variation-settings: 'FILL' 1;">edit</a>
                <a href="{{ path('admin_users_delete', {id: user.id}) }}" class="material-symbols-outlined text-error text-3xl cursor-pointer" onclick="return confirm('Excluir este usuário?')">delete</a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="bg-surface-container-low p-8 text-center">
        <p class="font-body-md text-on-surface-variant">Nenhum usuário cadastrado.</p>
    </div>
    {% endfor %}
</div>
{% endblock %}