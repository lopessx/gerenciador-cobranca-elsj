<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Gestor de Cobranças{% endblock %} | Cobri ELSJ</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>💳</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    <style>
        .blueprint-grid {
            background-image:
                linear-gradient(rgba(255, 241, 212, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 241, 212, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .gold-gradient {
            background: linear-gradient(135deg, #fdd150 0%, #ecc242 100%);
        }
        .gold-gradient-btn {
            background: linear-gradient(135deg, #fdd150 0%, #ecc242 100%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .gold-gradient-btn:hover {
            box-shadow: 0px 0px 12px rgba(253, 209, 80, 0.3);
            opacity: 0.95;
        }
        .gold-gradient-btn:active {
            transform: scale(0.98);
        }
        .ghost-border {
            border: 1px solid rgba(77, 70, 53, 0.15);
        }
        .glass-panel {
            background: rgba(52, 52, 57, 0.6);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(77, 70, 53, 0.15);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(77, 70, 53, 0.3);
            border-radius: 2px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(77, 70, 53, 0.5);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-primary-container selection:text-on-primary-container min-h-screen flex">
<div class="fixed inset-0 blueprint-grid pointer-events-none"></div>
<div class="flex min-h-screen w-full">
<!-- SideNavBar -->
<aside class="hidden md:flex flex-col h-screen sticky top-0 left-0 w-64 bg-surface-container-lowest flex-shrink-0 border-r border-outline-variant/15 z-30">
    <div class="p-6 flex flex-col gap-2">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-primary-container flex items-center justify-center rounded">
                <span class="material-symbols-outlined text-on-primary-container" style="font-variation-settings: 'FILL' 1;">dentistry</span>
            </div>
            <div>
                <h1 class="font-headline-sm text-headline-sm text-primary leading-tight">Admin Console</h1>
                <p class="text-[10px] text-on-surface-variant tracking-[0.2em] uppercase">Alternar Unidade</p>
            </div>
        </div>
        <!-- CTA Button -->
        <a href="{{ path('admin_billings_new') }}" class="gold-gradient-btn w-full py-3 text-on-primary font-label-md text-center rounded transition-all active:scale-[0.98] flex items-center justify-center gap-2" style="text-decoration: none;">
            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">add</span>
            <span>Nova Cobrança</span>
        </a>
    </div>
    <nav class="flex-1 px-2 space-y-1">
        {% set current_route = app.current_route ?? '' %}
        <a href="{{ path('dashboard') }}" class="flex items-center gap-4 text-on-surface-variant px-4 py-3 hover:bg-surface-container-low hover:text-primary transition-all duration-200 rounded {% if current_route == 'dashboard' %}text-primary bg-surface-container-highest border-l-4 border-primary{% endif %}">
            <span class="material-symbols-outlined" {% if current_route == 'dashboard' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>dashboard</span>
            <span class="font-label-md text-label-md">Dashboard</span>
        </a>
        <a href="{{ path('admin_companies') }}" class="flex items-center gap-4 text-on-surface-variant px-4 py-3 hover:bg-surface-container-low hover:text-primary transition-all duration-200 rounded {% if current_route starts with 'admin_comp' %}text-primary bg-surface-container-highest border-l-4 border-primary{% endif %}">
            <span class="material-symbols-outlined" {% if current_route starts with 'admin_comp' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>domain</span>
            <span class="font-label-md text-label-md">Empresas</span>
        </a>
        <a href="{{ path('admin_patients') }}" class="flex items-center gap-4 text-on-surface-variant px-4 py-3 hover:bg-surface-container-low hover:text-primary transition-all duration-200 rounded {% if current_route starts with 'admin_pat' %}text-primary bg-surface-container-highest border-l-4 border-primary{% endif %}">
            <span class="material-symbols-outlined" {% if current_route starts with 'admin_pat' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>person</span>
            <span class="font-label-md text-label-md">Pacientes</span>
        </a>
        <a href="{{ path('admin_billings') }}" class="flex items-center gap-4 text-on-surface-variant px-4 py-3 hover:bg-surface-container-low hover:text-primary transition-all duration-200 rounded {% if current_route starts with 'admin_bill' %}text-primary bg-surface-container-highest border-l-4 border-primary{% endif %}">
            <span class="material-symbols-outlined" {% if current_route starts with 'admin_bill' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>receipt_long</span>
            <span class="font-label-md text-label-md">Faturas</span>
        </a>
        <a href="{{ path('admin_users') }}" class="flex items-center gap-4 text-on-surface-variant px-4 py-3 hover:bg-surface-container-low hover:text-primary transition-all duration-200 rounded {% if current_route starts with 'admin_user' %}text-primary bg-surface-container-highest border-l-4 border-primary{% endif %}">
            <span class="material-symbols-outlined" {% if current_route starts with 'admin_user' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>group</span>
            <span class="font-label-md text-label-md">Usuários</span>
        </a>
    </nav>
    <!-- Sidebar Footer -->
    <div class="p-6 mt-auto border-t border-outline-variant/10">
        <nav class="flex flex-col gap-1 mb-6">
            <a href="#" class="flex items-center gap-4 text-on-surface-variant px-4 py-2 hover:text-secondary transition-opacity hover:opacity-70 rounded">
                <span class="material-symbols-outlined">help</span>
                <span class="font-label-sm text-label-sm">Suporte</span>
            </a>
            <a href="#" class="flex items-center gap-4 text-on-surface-variant px-4 py-2 hover:text-secondary transition-opacity hover:opacity-70 rounded">
                <span class="material-symbols-outlined">history</span>
                <span class="font-label-sm text-label-sm">Logs de Auditoria</span>
            </a>
        </nav>
        <!-- User Profile -->
        {% if app.user %}
        <div class="flex items-center gap-3 px-4">
            <div class="w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant/20 flex items-center justify-center overflow-hidden flex-shrink-0">
                <span class="material-symbols-outlined text-primary text-lg">account_circle</span>
            </div>
            <div class="flex flex-col min-w-0">
                <span class="font-label-md text-on-surface truncate">{{ app.user.name ?? app.user.email ?? 'Usuário' }}</span>
                <span class="text-[10px] uppercase tracking-tighter text-on-surface-variant opacity-50 truncate">Admin</span>
            </div>
            <a href="{{ path('app_logout') }}" class="ml-auto text-on-surface-variant hover:text-error transition-colors" title="Sair">
                <span class="material-symbols-outlined text-lg">logout</span>
            </a>
        </div>
        {% endif %}
    </div>
</aside>

<!-- Main Content -->
<main class="flex-1 flex flex-col min-w-0 bg-surface">
    <!-- TopNavBar -->
    <header class="w-full top-0 sticky z-20 bg-surface flex justify-between items-center px-margin-desktop py-6 transition-all duration-300" id="main-header">
        <div class="flex items-center gap-8">
            <div class="flex flex-col">
                <span class="font-display-lg text-[24px] text-primary tracking-tighter uppercase font-extrabold">Cobri ELSJ</span>
                <span class="text-[10px] text-outline tracking-[0.3em] font-label-sm">SISTEMAS DE FATURAMENTO ODONTOLÓGICO</span>
            </div>
            <nav class="hidden md:flex items-center gap-8">
                <a href="{{ path('dashboard') }}" class="font-label-md text-label-md transition-colors duration-300 {% if current_route == 'dashboard' %}text-primary font-bold border-b-2 border-primary pb-1{% else %}text-on-surface-variant hover:text-primary-fixed{% endif %}">Dashboard</a>
                <a href="{{ path('admin_billings') }}" class="font-label-md text-label-md transition-colors duration-300 {% if current_route starts with 'admin_bill' %}text-primary font-bold border-b-2 border-primary pb-1{% else %}text-on-surface-variant hover:text-primary-fixed{% endif %}">Cobranças</a>
                <a href="{{ path('admin_patients') }}" class="font-label-md text-label-md transition-colors duration-300 {% if current_route starts with 'admin_pat' %}text-primary font-bold border-b-2 border-primary pb-1{% else %}text-on-surface-variant hover:text-primary-fixed{% endif %}">Pacientes</a>
                <a href="{{ path('admin_companies') }}" class="font-label-md text-label-md transition-colors duration-300 {% if current_route starts with 'admin_comp' %}text-primary font-bold border-b-2 border-primary pb-1{% else %}text-on-surface-variant hover:text-primary-fixed{% endif %}">Configurações</a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined cursor-pointer hover:text-primary transition-colors text-on-surface-variant">notifications</span>
            <span class="material-symbols-outlined cursor-pointer hover:text-primary transition-colors text-on-surface-variant">account_balance</span>
            <div class="w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant/15 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-lg">account_circle</span>
            </div>
            <button class="md:hidden material-symbols-outlined text-on-surface cursor-pointer" onclick="document.querySelector('aside').classList.toggle('hidden');">menu</button>
        </div>
    </header>

    <div class="flex-1 px-margin-mobile md:px-margin-desktop py-8 lg:py-12 flex flex-col max-w-[1400px] w-full">
        {% block body %}{% endblock %}
    </div>

    <!-- Footer -->
    <footer class="w-full py-12 mt-section-gap flex flex-col md:flex-row justify-between items-center px-margin-mobile md:px-margin-desktop gap-gutter bg-surface-container-low border-t border-outline-variant/10">
        <div class="flex flex-col gap-1">
            <p class="font-label-sm text-label-sm text-on-surface-variant">© 2024 Cobri ELSJ. Sistemas de Faturamento de Precisão.</p>
            <p class="text-[9px] text-outline uppercase tracking-widest">Versão Institucional 4.2.19_b</p>
        </div>
        <div class="flex gap-6 md:gap-10">
            <a class="text-on-surface-variant font-label-sm hover:text-secondary transition-opacity hover:opacity-70" href="#">Documentação</a>
            <a class="text-on-surface-variant font-label-sm hover:text-secondary transition-opacity hover:opacity-70" href="#">Referência da API</a>
            <a class="text-on-surface-variant font-label-sm hover:text-secondary transition-opacity hover:opacity-70" href="#">Termos de Serviço</a>
        </div>
    </footer>
</main>
</div>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden fixed bottom-0 left-0 w-full bg-surface-container border-t border-outline-variant/10 flex justify-around py-3 z-50">
    <a href="{{ path('dashboard') }}" class="flex flex-col items-center gap-0.5 {% if current_route == 'dashboard' %}text-primary{% else %}text-on-surface-variant{% endif %} no-underline">
        <span class="material-symbols-outlined" {% if current_route == 'dashboard' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>dashboard</span>
        <span class="text-[9px] uppercase font-bold">Início</span>
    </a>
    <a href="{{ path('admin_billings') }}" class="flex flex-col items-center gap-0.5 {% if current_route starts with 'admin_bill' %}text-primary{% else %}text-on-surface-variant{% endif %} no-underline">
        <span class="material-symbols-outlined" {% if current_route starts with 'admin_bill' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>receipt_long</span>
        <span class="text-[9px] uppercase">Cobr</span>
    </a>
    <a href="{{ path('admin_patients') }}" class="flex flex-col items-center gap-0.5 {% if current_route starts with 'admin_pat' %}text-primary{% else %}text-on-surface-variant{% endif %} no-underline">
        <span class="material-symbols-outlined" {% if current_route starts with 'admin_pat' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>person</span>
        <span class="text-[9px] uppercase">Pac</span>
    </a>
    <a href="{{ path('admin_companies') }}" class="flex flex-col items-center gap-0.5 {% if current_route starts with 'admin_comp' %}text-primary{% else %}text-on-surface-variant{% endif %} no-underline">
        <span class="material-symbols-outlined" {% if current_route starts with 'admin_comp' %}style="font-variation-settings: 'FILL' 1;"{% endif %}>domain</span>
        <span class="text-[9px] uppercase">Emp</span>
    </a>
</nav>

<!-- FAB for mobile -->
<a href="{{ path('admin_billings_new') }}" class="md:hidden fixed bottom-20 right-6 w-14 h-14 rounded-full gold-gradient text-on-primary flex items-center justify-center shadow-xl active:scale-95 transition-transform z-50 no-underline" style="box-shadow: 0 4px 24px rgba(253, 209, 80, 0.3);">
    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add</span>
</a>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Header scroll effect
    const header = document.getElementById('main-header');
    const mainContent = document.querySelector('main');
    if (header && mainContent) {
        mainContent.addEventListener('scroll', () => {
            if (mainContent.scrollTop > 50) {
                header.classList.add('bg-surface-container-lowest\/80', 'backdrop-blur-md');
                header.classList.remove('bg-surface');
            } else {
                header.classList.remove('bg-surface-container-lowest\/80', 'backdrop-blur-md');
                header.classList.add('bg-surface');
            }
        });
    }

    // Button micro-interactions
    document.querySelectorAll('button, a').forEach(el => {
        el.addEventListener('mousedown', () => { el.style.opacity = '0.8'; });
        el.addEventListener('mouseup', () => { el.style.opacity = '1'; });
        el.addEventListener('mouseleave', () => { el.style.opacity = '1'; });
    });

    // Mobile sidebar toggle
    const menuBtn = document.querySelector('.md\\:hidden.material-symbols-outlined');
    const sidebar = document.querySelector('aside');
    if (menuBtn && sidebar) {
        menuBtn.addEventListener('click', () => {
            sidebar.classList.toggle('hidden');
            sidebar.classList.toggle('fixed');
            sidebar.classList.toggle('inset-0');
            sidebar.classList.toggle('z-50');
        });
    }
});
</script>
</body>
</html>