<!DOCTYPE html>
<html class="dark" lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Cobri ELSJ</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>💳</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-tertiary-fixed: #e8e3ca;
            --color-surface-container: #1e1f24;
            --color-background: #121317;
            --color-error: #ffb4ab;
            --color-outline: #9a907b;
            --color-surface-container-low: #1a1b20;
            --color-primary: #fff1d4;
            --color-on-surface-variant: #d1c5af;
            --color-inverse-primary: #755b00;
            --color-on-secondary-fixed-variant: #574500;
            --color-on-background: #e3e2e7;
            --color-surface-tint: #ecc242;
            --color-on-primary-fixed-variant: #584400;
            --color-surface-container-highest: #2D2E35;
            --color-on-secondary-container: #edcf71;
            --color-on-primary: #3D2E00;
            --color-tertiary-container: #dbd6be;
            --color-surface-container-high: #232429;
            --color-primary-container: #fdd150;
            --color-inverse-surface: #e3e2e7;
            --color-primary-fixed: #ffe08e;
            --color-secondary-fixed: #ffe084;
            --color-on-surface: #E3E2E7;
            --color-surface-bright: #38393d;
            --color-surface: #121317;
            --color-on-tertiary-fixed-variant: #4a4735;
            --color-error-container: #93000a;
            --color-tertiary: #f8f2d9;
            --color-on-secondary: #3c2f00;
            --color-primary-fixed-dim: #ecc242;
            --color-inverse-on-surface: #2f3035;
            --color-outline-variant: #4d4635;
            --color-secondary-fixed-dim: #e2c468;
            --color-surface-dim: #121317;
            --color-tertiary-fixed-dim: #ccc7af;
            --color-surface-container-lowest: #0d0e12;
            --color-on-tertiary: #333120;
            --color-secondary: #e2c468;
            --color-on-primary-fixed: #241a00;
            --color-on-secondary-fixed: #231b00;
            --color-secondary-container: #6d5700;
            --color-surface-variant: #343439;
            --color-on-tertiary-fixed: #1e1c0d;
            --color-on-error-container: #ffdad6;
            --color-on-primary-container: #725900;
            --color-on-error: #690005;
            --color-on-tertiary-container: #605d4a;
            --font-body-md: 'Inter', sans-serif;
            --font-label-md: 'Inter', sans-serif;
            --font-label-sm: 'Inter', sans-serif;
            --font-body-lg: 'Inter', sans-serif;
            --font-headline-sm: 'Plus Jakarta Sans', sans-serif;
            --font-display-lg: 'Plus Jakarta Sans', sans-serif;
            --font-display-lg-mobile: 'Plus Jakarta Sans', sans-serif;
            --font-headline-lg: 'Plus Jakarta Sans', sans-serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-body-md);
            background-color: #121317;
            color: #E3E2E7;
            overflow: hidden;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-panel {
            background: rgba(52, 52, 57, 0.6);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(77, 70, 53, 0.15);
        }

        .gold-gradient-btn {
            background: linear-gradient(135deg, #fdd150 0%, #ecc242 100%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border: none;
            font-family: var(--font-label-md);
            font-size: 14px;
            line-height: 20px;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--color-on-primary);
        }

        .gold-gradient-btn:hover {
            box-shadow: 0px 0px 12px rgba(253, 209, 80, 0.3);
            opacity: 0.95;
        }

        .gold-gradient-btn:active {
            transform: scale(0.98);
        }

        .minimal-input {
            background: transparent;
            border: none;
            border-bottom: 1px solid rgba(77, 70, 53, 0.4);
            border-radius: 0;
            padding: 0.75rem 0;
            width: 100%;
            color: var(--color-primary);
            font-family: var(--font-body-lg);
            font-size: 18px;
            line-height: 28px;
            transition: all 0.3s ease;
        }

        .minimal-input:focus {
            outline: none;
            box-shadow: none;
            border-bottom: 2px solid #fff1d4;
        }

        .minimal-input::placeholder {
            opacity: 0.2;
            color: var(--color-primary);
        }

        .architectural-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background-image: radial-gradient(circle at 2px 2px, rgba(255, 241, 212, 0.05) 1px, transparent 0);
            background-size: 40px 40px;
        }

        .float-decoration {
            position: absolute;
            width: 1px;
            background: linear-gradient(to bottom, transparent, #fff1d4, transparent);
            opacity: 0.1;
        }

        .ambient-glow {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: -1;
        }

        .font-display-lg {
            font-family: var(--font-display-lg);
            font-size: 56px;
            line-height: 64px;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        @media (max-width: 768px) {
            .font-display-lg {
                font-size: 40px;
                line-height: 48px;
                letter-spacing: -0.01em;
            }
        }

        .font-headline-lg {
            font-family: var(--font-headline-lg);
            font-size: 32px;
            line-height: 40px;
            font-weight: 600;
        }

        .font-body-md {
            font-family: var(--font-body-md);
            font-size: 16px;
            line-height: 24px;
            font-weight: 400;
        }

        .font-label-md {
            font-family: var(--font-label-md);
            font-size: 14px;
            line-height: 20px;
            font-weight: 500;
            letter-spacing: 0.05em;
        }

        .font-label-sm {
            font-family: var(--font-label-sm);
            font-size: 12px;
            line-height: 16px;
            font-weight: 600;
            letter-spacing: 0.05em;
        }

        .text-primary { color: var(--color-primary); }
        .text-on-surface { color: var(--color-on-surface); }
        .text-on-surface-variant { color: var(--color-on-surface-variant); }
        .text-on-primary { color: var(--color-on-primary); }
        .text-error { color: var(--color-error); }

        .uppercase { text-transform: uppercase; }
        .tracking-widest { letter-spacing: 0.2em; }
        .tracking-tighter { letter-spacing: -0.03em; }

        .flash-message {
            padding: 1rem;
            border-radius: 0.25rem;
            font-family: var(--font-label-md);
            font-size: 14px;
            line-height: 20px;
            font-weight: 500;
        }

        .flash-message.error {
            background: var(--color-error-container);
            color: var(--color-on-error-container);
        }
    </style>
</head>
<body>
    <div class="architectural-bg"></div>
    <div class="float-decoration" style="height: 614px; left: 15%; top: -10%;"></div>
    <div class="float-decoration" style="height: 409px; right: 20%; bottom: -5%;"></div>
    <div class="ambient-glow" style="top: -10%; right: -10%; width: 50vw; height: 50vw; background: rgba(255, 241, 212, 0.03); filter: blur(120px);"></div>
    <div class="ambient-glow" style="bottom: -10%; left: -10%; width: 40vw; height: 40vw; background: rgba(109, 87, 0, 0.03); filter: blur(120px);"></div>

    <main style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem;">
        <!-- Cabeçalho da Marca -->
        <header style="margin-bottom: 3rem; text-align: center;">
            <h1 style="font-family: var(--font-display-lg); font-size: 56px; line-height: 64px; font-weight: 700; letter-spacing: -0.02em; color: var(--color-primary); text-transform: uppercase; margin-bottom: 0.5rem;">Cobri ELSJ</h1>
            <p style="font-family: var(--font-label-md); font-size: 14px; line-height: 20px; font-weight: 500; letter-spacing: 0.05em; color: var(--color-on-surface-variant); text-transform: uppercase; opacity: 0.6;">Sistemas de Faturamento de Precisão</p>
        </header>

        <!-- Container de Login -->
        <div class="glass-panel" style="width: 100%; max-width: 480px; padding: 2rem 3rem; position: relative; overflow: hidden; border-radius: 0.25rem;">
            {% if error %}
                <div class="flash-message error" style="margin-bottom: 1.5rem;">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form action="{{ path('app_login') }}" method="post" style="display: flex; flex-direction: column; gap: 2.5rem;">
                <div>
                    <h2 style="font-family: var(--font-headline-lg); font-size: 32px; line-height: 40px; font-weight: 600; color: var(--color-on-surface); margin-bottom: 0.5rem;">Acesso ao Terminal</h2>
                    <p style="font-family: var(--font-body-md); font-size: 16px; line-height: 24px; font-weight: 400; color: var(--color-on-surface-variant);">Insira suas credenciais para sincronizar os dados do sistema.</p>
                </div>

                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <div>
                        <label style="display: block; font-family: var(--font-label-sm); font-size: 12px; line-height: 16px; font-weight: 600; letter-spacing: 0.05em; color: var(--color-on-surface-variant); text-transform: uppercase; margin-bottom: 0.25rem;">Identificador de Usuário</label>
                        <input class="minimal-input" type="text" name="_username" value="{{ last_username }}" placeholder="ADMIN_091" required autocomplete="username">
                    </div>
                    <div>
                        <label style="display: block; font-family: var(--font-label-sm); font-size: 12px; line-height: 16px; font-weight: 600; letter-spacing: 0.05em; color: var(--color-on-surface-variant); text-transform: uppercase; margin-bottom: 0.25rem;">Token de Acesso</label>
                        <input class="minimal-input" type="password" name="_password" placeholder="••••••••" required autocomplete="current-password">
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                </div>

                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <button type="submit" class="gold-gradient-btn" style="width: 100%; padding: 1rem; font-weight: 700; letter-spacing: 0.2em;">
                        Inicializar Sessão
                    </button>
                    <a href="#" style="text-align: center; font-family: var(--font-label-sm); font-size: 12px; line-height: 16px; font-weight: 600; letter-spacing: 0.05em; color: var(--color-on-surface-variant); text-transform: uppercase; opacity: 0.5; text-decoration: none; transition: opacity 0.2s;">
                        Solicitar Link de Recuperação
                    </a>
                </div>
            </form>

            <!-- Detalhe Técnico Decorativo -->
            <div style="position: absolute; bottom: 0; right: 0; padding: 0.5rem; opacity: 0.1; pointer-events: none;">
                <span style="font-family: var(--font-label-sm); font-size: 8px; color: var(--color-primary);">SECURE_AUTH_ENCRYPTION_v4.2.0_READY</span>
            </div>
        </div>

        <!-- Rodapé -->
        <footer style="margin-top: 3rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; opacity: 0.4;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span class="material-symbols-outlined" style="font-size: 16px;">lock_open</span>
                <span class="font-label-sm" style="font-family: var(--font-label-sm); font-size: 12px; line-height: 16px; font-weight: 600; letter-spacing: 0.05em;">CONFORMIDADE ISO-27001</span>
            </div>
            <div style="font-family: var(--font-label-sm); font-size: 12px; line-height: 16px; font-weight: 600; letter-spacing: 0.05em;">© 2024 COBRI ELSJ CORP.</div>
        </footer>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('form');
            if (!form) return;

            form.addEventListener('submit', (e) => {
                const btn = e.target.querySelector('button[type="submit"]');
                if (btn) {
                    const originalText = btn.innerText;
                    btn.innerText = 'SINCRONIZANDO...';
                    btn.classList.add('opacity-50', 'cursor-not-allowed');
                    btn.style.opacity = '0.5';
                    btn.style.cursor = 'not-allowed';
                }
            });
        });
    </script>
</body>
</html>