{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<!-- Seção Editorial Hero -->
<section class="mb-section-gap">
    <div class="max-w-4xl">
        <div class="flex items-center gap-2 mb-4">
            <span class="w-12 h-[1px] bg-primary"></span>
            <span class="font-label-sm text-label-sm text-primary tracking-[0.2em] uppercase">Resumo Executivo</span>
        </div>
        <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface leading-none mb-6">Integridade Estrutural das <span class="text-primary italic">Liquidações.</span></h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant/80 max-w-2xl">
            Visão consolidada do faturamento odontológico, ciclos de cobrança e métricas de performance financeira.
        </p>
    </div>
</section>

<!-- Linha de Estatísticas de Precisão -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-gutter mb-12">
    <div class="bg-surface-container-low p-6 flex flex-col gap-1 group transition-all duration-300">
        <span class="font-label-sm text-label-sm text-on-surface-variant/60 uppercase tracking-widest">FATURAS PAGAS</span>
        <span class="font-display-lg text-[32px] text-primary">{{ totalPaid }}</span>
        <div class="w-full h-1 bg-surface-container-highest mt-4 overflow-hidden">
            <div class="h-full bg-primary w-2/3 group-hover:w-full transition-all duration-700"></div>
        </div>
    </div>
    <div class="bg-surface-container-low p-6 flex flex-col gap-1 group transition-all duration-300">
        <span class="font-label-sm text-label-sm text-on-surface-variant/60 uppercase tracking-widest">A RECEBER</span>
        <span class="font-display-lg text-[32px] text-on-surface">{{ totalActive }}</span>
        <div class="w-full h-1 bg-surface-container-highest mt-4 overflow-hidden">
            <div class="h-full bg-secondary w-[94.2%] group-hover:opacity-80 transition-all duration-700"></div>
        </div>
    </div>
    <div class="bg-surface-container-low p-6 flex flex-col gap-1 group transition-all duration-300">
        <span class="font-label-sm text-label-sm text-on-surface-variant/60 uppercase tracking-widest">ATRASADAS</span>
        <span class="font-display-lg text-[32px] text-error">{{ totalOverdue }}</span>
        <div class="w-full h-1 bg-surface-container-highest mt-4 overflow-hidden">
            <div class="h-full bg-error w-[3%]"></div>
        </div>
    </div>
    <div class="bg-surface-container-low p-6 flex flex-col gap-1 group transition-all duration-300">
        <span class="font-label-sm text-label-sm text-on-surface-variant/60 uppercase tracking-widest">VALOR A RECEBER</span>
        <span class="font-display-lg text-[32px] text-on-surface">R$ {{ (amountPending / 100)|number_format(2, ',', '.') }}</span>
        <div class="w-full h-1 bg-surface-container-highest mt-4 overflow-hidden">
            <div class="h-full bg-primary-fixed-dim w-1/2"></div>
        </div>
    </div>
</div>

<!-- Seção de Documentação Recente -->
<section class="mb-section-gap">
    <div class="flex justify-between items-end mb-12">
        <div>
            <h3 class="font-headline-lg text-headline-lg text-on-surface">Faturas Recentes</h3>
            <p class="font-body-md text-on-surface-variant/60 mt-1">Últimas cobranças registradas no sistema.</p>
        </div>
        <a class="font-label-md text-primary hover:underline underline-offset-8" href="{{ path('admin_billings') }}">VER TODAS AS FATURAS</a>
    </div>

    <div class="space-y-[80px]">
        {% for billing in recentBillings %}
        <div class="flex flex-col md:flex-row md:items-center justify-between group cursor-pointer">
            <div class="flex items-start gap-8">
                <span class="font-label-sm text-label-sm text-on-surface-variant/40 mt-2">{{ loop.index }}</span>
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="px-3 py-1 bg-surface-container-high text-label-sm text-primary uppercase ghost-border">{{ billing.status }}</span>
                        <span class="font-label-sm text-on-surface-variant opacity-60">FAT-{{ billing.id|slice(0, 8)|upper }}</span>
                    </div>
                    <h4 class="font-headline-sm text-headline-sm text-on-surface group-hover:text-primary transition-colors">{{ billing.patient.name }}</h4>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-1">{{ billing.company.name }}</p>
                </div>
            </div>
            <div class="mt-4 md:mt-0 md:text-right">
                <div class="font-label-sm text-on-surface-variant uppercase tracking-widest mb-1">Valor Devido</div>
                <div class="font-headline-sm text-primary">R$ {{ (billing.totalAmount / 100)|number_format(2, ',', '.') }}</div>
                <div class="font-label-sm text-on-surface-variant mt-2">Emitido em: {{ billing.createdAt|date('d M, Y') }}</div>
            </div>
        </div>
        {% else %}
        <div class="bg-surface-container-low p-8 text-center">
            <p class="font-body-md text-on-surface-variant">Nenhuma fatura registrada ainda.</p>
        </div>
        {% endfor %}
    </div>
</section>
{% endblock %}